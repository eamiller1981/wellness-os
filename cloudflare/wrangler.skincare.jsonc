{
  "name": "skincare",
  "main": "./skincare-worker.js",
  "compatibility_date": "2026-04-20",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "kv_namespaces": [
    {
      "binding": "SKINCARE_STATE",
      "id": "c43f2e7539bf41388740a844efecd157"
    }
  ],
