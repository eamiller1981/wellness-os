{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/budget-abroad/biweekly", "destination": "/budget-abroad/Biweekly%20Cockpit.dc" },
    { "source": "/budget-abroad/dashboard", "destination": "/budget-abroad/Dashboard.dc" },
    { "source": "/budget-abroad/forecast", "destination": "/budget-abroad/Forecast%20Planner.dc" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
